# в”Ђв”Ђ Stage 1: build в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

# VITE_* vars must be baked in at build time вЂ” passed via docker-compose build args.
# Values come from the root .env file (never committed вЂ” listed in .gitignore).
ARG VITE_FIREBASE_API_KEY
ARG VITE_FIREBASE_AUTH_DOMAIN
ARG VITE_FIREBASE_PROJECT_ID
ARG VITE_FIREBASE_STORAGE_BUCKET
ARG VITE_FIREBASE_MESSAGING_SENDER_ID
ARG VITE_FIREBASE_APP_ID
ARG VITE_FIREBASE_MEASUREMENT_ID
ARG VITE_GOOGLE_MAPS_API_KEY
ARG VITE_MAPS_WRAPPER_URL
ARG VITE_KONG_BASE_URL
ARG VITE_KONG_API_KEY
ARG VITE_TRAIL_QUERY_URL
ARG VITE_API_BASE_URL
ARG VITE_ORCHESTRATOR_URL
ARG VITE_HAZARD_REPORT_URL
ARG VITE_ALT_ROUTE_URL
ARG VITE_INCIDENT_URL
ARG VITE_HIKE_URL

ENV VITE_FIREBASE_API_KEY=$VITE_FIREBASE_API_KEY
ENV VITE_FIREBASE_AUTH_DOMAIN=$VITE_FIREBASE_AUTH_DOMAIN
ENV VITE_FIREBASE_PROJECT_ID=$VITE_FIREBASE_PROJECT_ID
ENV VITE_FIREBASE_STORAGE_BUCKET=$VITE_FIREBASE_STORAGE_BUCKET
ENV VITE_FIREBASE_MESSAGING_SENDER_ID=$VITE_FIREBASE_MESSAGING_SENDER_ID
ENV VITE_FIREBASE_APP_ID=$VITE_FIREBASE_APP_ID
ENV VITE_FIREBASE_MEASUREMENT_ID=$VITE_FIREBASE_MEASUREMENT_ID
ENV VITE_GOOGLE_MAPS_API_KEY=$VITE_GOOGLE_MAPS_API_KEY
ENV VITE_MAPS_WRAPPER_URL=$VITE_MAPS_WRAPPER_URL
ENV VITE_KONG_BASE_URL=$VITE_KONG_BASE_URL
ENV VITE_KONG_API_KEY=$VITE_KONG_API_KEY
ENV VITE_TRAIL_QUERY_URL=$VITE_TRAIL_QUERY_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_ORCHESTRATOR_URL=$VITE_ORCHESTRATOR_URL
ENV VITE_HAZARD_REPORT_URL=$VITE_HAZARD_REPORT_URL
ENV VITE_ALT_ROUTE_URL=$VITE_ALT_ROUTE_URL
ENV VITE_INCIDENT_URL=$VITE_INCIDENT_URL
ENV VITE_HIKE_URL=$VITE_HIKE_URL

RUN npm run build

# в”Ђв”Ђ Stage 2: serve в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
